# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.
# On Render/Railway/Fly etc., set these in the platform's
# environment-variable / secret UI instead of using a file.

# OpenAI (used by question generation, concept extraction, pre-learning)
OPENAI_API_KEY=

# Mathpix (used by PDF/image -> MMD conversion)
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# Live mode is ON by default when the keys above are set.
# Dry/stub generation is disabled in production — set AEGIS_ALLOW_DRY=1 only for
# local testing without API keys (never in production).
# AEGIS_ALLOW_DRY=0

# Force dry mode even when keys are present (tests/CI only):
# AEGIS_USE_LIVE=0

# Optional: OpenAI model slug
# AEGIS_OPENAI_MODEL=gpt-5.6-luna

# Max output/completion tokens per GPT call (gpt-5.4 supports up to 128000)
# AEGIS_OPENAI_MAX_OUTPUT_TOKENS=128000

# Characters of MMD sent to GPT per chunk. Large chapters are processed in
# ordered chunks (never trimmed) and merged, so no content is lost.
# AEGIS_MMD_CHUNK_CHARS=45000

# Password for the Admin tab (edit GPT prompts). CHANGE THIS in production.
# AEGIS_ADMIN_PASSWORD=admin

# Optional: where the backend stores Bulk Import workbooks
# AEGIS_DATA_DIR=/app/data
